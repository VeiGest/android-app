<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/Background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Back Arrow Header -->
        <ImageView
            android:id="@+id/ivBackArrow"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back_arrow"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Voltar"
            android:layout_gravity="start"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="30dp"
                android:src="@drawable/ic_veigest" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recuperar Password"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="?attr/TextBoxText"
                android:layout_marginBottom="30dp" />

        <!-- STEP 1: Username, Current Password and Method Selection -->
        <LinearLayout
            android:id="@+id/layoutStep1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Insira o seu nome de utilizador:"
                android:textColor="?attr/TextBoxText"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Nome de utilizador"
                android:background="?attr/TextBox"
                android:textColor="?attr/TextBoxText"
                android:textColorHint="?attr/TextHint"
                android:padding="14dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnVerifyUsername"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Verificar Utilizador"
                android:textStyle="bold"
                android:textSize="16sp"
                android:backgroundTint="?attr/ButtonBackground"
                android:textColor="?attr/ButtonText"
                style="?attr/buttonStyle"
                android:layout_marginBottom="20dp" />

            <!-- Recovery Options (hidden until username verified) -->
            <LinearLayout
                android:id="@+id/layoutRecoveryOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Como deseja receber o código?"
                    android:textColor="?attr/TextBoxText"
                    android:layout_marginBottom="12dp" />

                <Spinner
                    android:id="@+id/spinnerRecoveryMethod"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="?attr/TextBox"
                    android:layout_marginBottom="12dp"
                    android:spinnerMode="dropdown" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Email associado"
                    android:background="?attr/TextBox"
                    android:textColor="?attr/TextBoxText"
                    android:textColorHint="?attr/TextHint"
                    android:inputType="textEmailAddress"
                    android:padding="14dp"
                    android:layout_marginBottom="20dp"
                    android:enabled="false"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnSendCode"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="Enviar Código"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:backgroundTint="?attr/ButtonBackground"
                    android:textColor="?attr/ButtonText"
                    style="?attr/buttonStyle"
                    android:layout_marginBottom="20dp" />

            </LinearLayout>
        </LinearLayout>

        <!-- STEP 2: Code Verification -->
        <LinearLayout
            android:id="@+id/layoutStep2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvCodeSentMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Código enviado!"
                android:textColor="?attr/LinkText"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Insira o código de 6 dígitos:"
                android:textColor="?attr/TextBoxText"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etRecoveryCode"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="000000"
                android:inputType="number"
                android:maxLength="6"
                android:background="?attr/TextBox"
                android:textColor="?attr/TextBoxText"
                android:textColorHint="?attr/TextHint"
                android:padding="14dp"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnVerifyCode"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Verificar Código"
                android:textStyle="bold"
                android:textSize="16sp"
                android:backgroundTint="?attr/ButtonBackground"
                android:textColor="?attr/ButtonText"
                style="?attr/buttonStyle"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/tvResendCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reenviar código"
                android:textColor="#2196F3"
                android:textSize="16sp"
                android:layout_gravity="center_horizontal"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvBackToStep1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voltar atrás"
                android:textColor="#2196F3"
                android:textSize="16sp"
                android:layout_gravity="center_horizontal"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:layout_marginBottom="10dp" />
        </LinearLayout>

        <!-- STEP 3: New Password -->
        <LinearLayout
            android:id="@+id/layoutStep3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Defina a nova password:"
                android:textColor="?attr/TextBoxText"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etNewPassword"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Nova Password"
                android:inputType="textPassword"
                android:background="?attr/TextBox"
                android:textColor="?attr/TextBoxText"
                android:textColorHint="?attr/TextHint"
                android:padding="14dp"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Confirmar Password"
                android:inputType="textPassword"
                android:background="?attr/TextBox"
                android:textColor="?attr/TextBoxText"
                android:textColorHint="?attr/TextHint"
                android:padding="14dp"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnResetPassword"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Redefinir Password"
                android:textStyle="bold"
                android:textSize="16sp"
                android:backgroundTint="?attr/ButtonBackground"
                android:textColor="?attr/ButtonText"
                style="?attr/buttonStyle"
                android:layout_marginBottom="20dp" />
        </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
